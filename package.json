  "description": "Excel 数据转换工具，支持智能字段映射和值转换规则配置",
  "main": "transform_excel.js",
  "scripts": {
    "start": "node transform_excel.js",
    "dev": "node src/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop excel-transformer",
    "pm2:restart": "pm2 restart excel-transformer",
    "pm2:logs": "pm2 logs excel-transformer",
    "pm2:monit": "pm2 monit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "expr-eval": "^2.0.2",
    "formidable": "^3.5.4",
    "pino": "^10.3.1",
